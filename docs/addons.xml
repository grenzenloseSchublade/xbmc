<?xml version='1.0' encoding='UTF-8'?>
<addons>
  <addon id="plugin.video.amazon-waipu" name="Amazon VOD (Enhanced)" version="1.2.2+waipu.1" provider-name="Sandmann79, Varstahl, grenzenloseSchublade">
